doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title PlaylistExchange
    link(rel="stylesheet", href="/Css/style.css")
    style.
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: "Trebuchet MS", "Segoe UI", Arial, sans-serif;
        background: linear-gradient(135deg, #eef6eb 0%, #ddeedd 100%);
        color: #2f3a2f;
        min-height: 100vh;
      }

      .home-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 40px;
        background: rgba(183, 211, 176, 0.7);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(144, 176, 139, 0.3);
      }

      .home-nav .brand {
        font-size: 1.4rem;
        font-weight: 800;
        color: #2f3a2f;
        text-decoration: none;
      }

      .home-nav .nav-links {
        display: flex;
        gap: 8px;
        align-items: center;
      }

      .home-nav .nav-links a {
        text-decoration: none;
        color: #2f3a2f;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: 999px;
        transition: all 0.2s ease;
      }

      .home-nav .nav-links a:hover {
        background: rgba(144, 176, 139, 0.4);
      }

      .home-nav .nav-links .btn-login {
        background: #2f3a2f;
        color: white;
        padding: 8px 20px;
        border-radius: 999px;
      }

      .home-nav .nav-links .btn-login:hover {
        background: #4a5e4a;
        opacity: 1;
      }

      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
      }

      .hero-left {
        padding: 120px 60px 80px 60px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .hero-title {
        font-size: 3.8rem;
        font-weight: 900;
        line-height: 1.08;
        color: #1a2e1a;
        margin-bottom: 20px;
        letter-spacing: -1.5px;
      }

      .hero-title span { color: #90b08b; }

      .hero-subtitle {
        font-size: 1.15rem;
        color: #4a5e4a;
        line-height: 1.7;
        max-width: 440px;
        margin-bottom: 36px;
      }

      .hero-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .btn-primary {
        background: #2f3a2f;
        color: white;
        padding: 14px 28px;
        border-radius: 999px;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.2s ease;
        display: inline-block;
      }

      .btn-primary:hover {
        background: #4a5e4a;
        transform: translateY(-1px);
      }

      .btn-secondary {
        background: rgba(144, 176, 139, 0.25);
        color: #2f3a2f;
        padding: 14px 28px;
        border-radius: 999px;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        border: 1.5px solid #b7d3b0;
        transition: all 0.2s ease;
        display: inline-block;
      }

      .btn-secondary:hover {
        background: rgba(144, 176, 139, 0.45);
        transform: translateY(-1px);
      }

      .hero-stats {
        display: flex;
        gap: 32px;
        margin-top: 48px;
        padding-top: 32px;
        border-top: 1px solid #d7e4d2;
      }

      .stat-item .stat-num {
        font-size: 2rem;
        font-weight: 900;
        color: #2f3a2f;
        line-height: 1;
      }

      .stat-item .stat-label {
        font-size: 0.85rem;
        color: #6b756b;
        margin-top: 4px;
      }

      .emoji-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        padding: 40px;
      }

      .emoji-card {
        background: rgba(255,255,255,0.7);
        backdrop-filter: blur(8px);
        border: 1px solid #d7e4d2;
        border-radius: 20px;
        padding: 28px 24px;
        text-align: center;
        transition: all 0.2s ease;
        box-shadow: 0 4px 16px rgba(85,107,85,0.08);
      }

      .emoji-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(85,107,85,0.15);
      }

      .emoji-card .emoji { font-size: 2.4rem; margin-bottom: 8px; }
      .emoji-card .label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #4a5e4a;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .features-strip {
        background: #2f3a2f;
        padding: 28px 60px;
        display: flex;
        justify-content: center;
        gap: 60px;
        flex-wrap: wrap;
      }

      .feature-item {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
        font-weight: 500;
      }

      .feature-icon { font-size: 1.4rem; }

      @media (max-width: 768px) {
        .hero { grid-template-columns: 1fr; }
        .hero-right { display: none; }
        .hero-left { padding: 100px 28px 40px; }
        .hero-title { font-size: 2.6rem; }
        .features-strip { padding: 24px 28px; gap: 24px; }
      }

  body
    nav.home-nav
      a.brand(href="/") PlaylistExchange
      .nav-links
        a(href="/Browse-Playlist") Browse
        a(href="/ratings") Ratings
        a(href="/Login").btn-login Login

    .hero
      .hero-left
        h1.hero-title
          | Share the 
          span Sound.
        p.hero-subtitle Find your vibe, set your mood and share it all!
        .hero-buttons
          a.btn-primary(href="/Browse-Playlist") Browse Playlists
          a.btn-secondary(href="/create-account") Create Account

        .hero-stats
          .stat-item
            .stat-num 25
            .stat-label Playlists
          .stat-item
            .stat-num 50
            .stat-label Songs
          .stat-item
            .stat-num 18
            .stat-label Mood tags
          .stat-item
            .stat-num 5
            .stat-label Members

      .hero-right

    .features-strip
      .feature-item
        span.feature-icon 🎧
        span Browse & discover playlists
      .feature-item
        span.feature-icon ✨
        span Drop a vibe rating
      .feature-item
        span.feature-icon 🎵
        span Open songs on Spotify
      .feature-item
        span.feature-icon 🌿
        span Filter by mood & genre
