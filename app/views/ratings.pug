extends layout

block content
  .page-wrap
    h1 Rate a User
    
    form(action='/rate/2' method='POST')
      label Score (1-5)
      select(name='score')
        option(value='5') ★★★★★
        option(value='4') ★★★★
        option(value='3') ★★★
        option(value='2') ★★
        option(value='1') ★
      label Comment
      textarea(name='comment' placeholder='Leave a comment...' rows='3')
      button(type='submit') Submit Rating

    h2 Recent Ratings
    each rating in ratings
      .playlist-card
        p
          strong= rating.rater_name
          |  rated 
          strong= rating.ratee_name
        p ★ #{rating.score}
        if rating.comment
          p= rating.comment