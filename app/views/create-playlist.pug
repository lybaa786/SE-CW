doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Create Playlist — PlaylistExchange
    link(rel="stylesheet", href="/Css/style.css")

  body
    .topbar
      a.brand(href="/") PlaylistExchange
      .topbar-right
        a.nav-link(href="/Browse-Playlist") Browse
        a.nav-link(href="/ratings") Ratings
        a.nav-link.active(href="/create-playlist") + New Playlist

    .page-wrap
      a.back-link(href="/Browse-Playlist") ← Back to Browse

      h1.page-title Create a Playlist
      p.page-subtitle Share your music taste with the community ♡

      .form-card
        form(action="/create-playlist" method="POST")

          .form-group
            label.form-label(for="title") Playlist Title
            input.form-input(
              type="text"
              id="title"
              name="title"
              placeholder="Give your playlist a name..."
              required
            )

          .form-group
            label.form-label(for="description") Description
            textarea.form-textarea(
              id="description"
              name="description"
              placeholder="What's the vibe of this playlist? Describe the mood, genre, or occasion..."
              required
            )

          .form-group
            label.form-label Genre
            .genre-grid
              each genre in ['R&B','Pop','Rap','Afrobeats','Reggae','Worship','Ambient','Alternative','Indie','Dance','Soul','Acoustic','Other']
                input.genre-option(type='radio' name='genre' id=`genre-${genre}` value=genre)
                label.genre-btn(for=`genre-${genre}`)= genre

          button.submit-btn(type="submit") Start the vibe!