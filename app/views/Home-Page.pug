extends layout 

block content 
  style. 
    body {
      padding-top: 120px;
      background-image: url("/Images/music-background.jpg");
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-color : #1cb85835;
      font-family: Arial, Helvetica, sans-serif;
    }

    /* overlay */
    body::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5); /* Adjust the opacity as needed */
      z-index: -1; /* Ensure the overlay is behind the content */
    }


    .container {
      width: 550px;
      margin: 80px auto; 
      padding: 20px;
      border: 1px solid #ccc;
      border: radius 5px;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      background-color: pink;
      text-align: center;
    }

    h1 {
      margin-bottom: 10px;
    }

    a {
      text-decoration: none;
    }

    button {
      margin: 10px;
      padding: 10px 20px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }

  .container
    h1 SharePlaylists 
    h2 Share the Sound.
    p Create and share your playlists with friends and family. Discover new music and enjoy your favorite tunes together.
    
    a(href="/create-account")
      button Create New Account

    a(href="/Login") 
      button Login