extends layout

block content
  .playlist-detail-page
    .detail-shell
      if flashMessage
        .flash-banner= flashMessage

      .detail-card
        .detail-head
          .detail-main
            a.back-link(href="/Browse-Playlist") ← Back to browse

            h1.playlist-name= pl.name

            if pl.ownerName
              p.owner-line by @#{pl.ownerName}
            else if pl.ownerId
              p.owner-line by user #{pl.ownerId}

            .meta-row
              if pl.genre
                span.meta-chip= pl.genre
              span.meta-chip #{pl.songs.length} song#{pl.songs.length === 1 ? '' : 's'}
              if pl.stats.avgRating
                span.meta-chip ⭐ #{pl.stats.avgRating}/5
              else
                span.meta-chip No ratings yet

            if pl.tags && pl.tags.length
              .tag-row
                each tag in pl.tags
                  span.tag-pill [#{tag.name}]

            p.playlist-desc= pl.description || "No description added yet."

          .detail-side
            if pl.viewerState.saved
              .saved-pill Saved
            else
              .saved-pill.not-saved Not saved

        .action-toolbar
          form.inline-form(action=`/playlists/${pl.id}/like` method="POST")
            input(type="hidden" name="action" value=pl.viewerState.liked ? "unlike" : "like")
            button.action-btn(type="submit" class=pl.viewerState.liked ? "active" : "")
              | ❤️ Like
              span.count= pl.stats.likesCount

          a.action-btn(href="#drop-vibe") ⭐ Rate

          a.action-btn.comment-jump(href="#comment-form")
            | 💬 Comment
            span.count= pl.stats.commentsCount

          form.inline-form(action=`/playlists/${pl.id}/save` method="POST")
            input(type="hidden" name="action" value=pl.viewerState.saved ? "unsave" : "save")
            button.action-btn(type="submit" class=pl.viewerState.saved ? "active" : "")
              | 💾 Save
              span.count= pl.stats.savesCount

      if currentUser
        .detail-section
          h2.section-title Add a Song
          form.comment-form(action=`/playlists/${pl.id}/add-song` method='POST')
            input.comment-input(type='text' name='title' placeholder='Song title *' required)
            input.comment-input(type='text' name='artist' placeholder='Artist')
            input.comment-input(type='text' name='album' placeholder='Album')
            input.comment-input(type='text' name='genre' placeholder='Genre e.g. R&B, Pop')
            input.comment-input(type='number' name='duration_secs' placeholder='Duration in seconds e.g. 209')
            input.comment-input(type='text' name='spotify_url' placeholder='Spotify URL')
            .comment-form-actions
              button.primary-btn(type='submit') + Add Song

      .detail-section
        h2.section-title TrackList

        if pl.songs && pl.songs.length
          ol.track-list
            each song, index in pl.songs
              li.track-item
                .track-copy
                  .track-line
                    span.track-number #{index + 1}.
                    span.track-title #{song.title}
                    if song.artist
                      span.track-sep  - 
                      span.track-artist= song.artist
                  if song.album || song.genre
                    .track-sub
                      if song.album
                        span= song.album
                      if song.album && song.genre
                        span  · 
                      if song.genre
                        span= song.genre
                .track-actions
                  if song.spotify_url
                    - const trackId = song.spotify_url.split('/track/')[1]?.split('?')[0]
                    if trackId 
                      iframe(
                        src=`https://open.spotify.com/embed/track/${trackId}`
                        width="100%"
                        height="152%"
                        frameborder="0%"
                        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                      )
        else
          p.empty-copy No songs in this playlist yet.

      .detail-section#comments
        h2.section-title Comments (#{pl.stats.commentsCount})

        if pl.comments && pl.comments.length
          .comments-list
            each comment in pl.comments
              .comment-card
                .comment-user @#{comment.user_name}
                p.comment-body= comment.body
        else
          p.empty-copy No comments yet. Be the first to comment.

        form.comment-form#comment-form(action=`/playlists/${pl.id}/comment` method="POST")
          textarea.comment-input(
            name="comment"
            rows="3"
            placeholder="Add comment..."
            required
          )
          .comment-form-actions
            button.primary-btn(type="submit") Post comment

      .detail-section
        h2.section-title#drop-vibe Drop a Vibe ♡
        p.empty-copy Rate this playlist with your mood

        form(action=`/rate/${pl.ownerId}` method='POST')
          input(type='hidden' name='playlistId' value=pl.id)
          input(type='hidden' name='playlist_title' value=pl.name)

          span.vibe-label What's the vibe?
          .vibe-grid
            input.vibe-option(type='radio' name='vibe' id='vibe1' value='Chill')
            label.vibe-btn(for='vibe1')
              span.icon 🌙
              | Chill
            input.vibe-option(type='radio' name='vibe' id='vibe2' value='Hype')
            label.vibe-btn(for='vibe2')
              span.icon 🔥
              | Hype
            input.vibe-option(type='radio' name='vibe' id='vibe3' value='Late-night')
            label.vibe-btn(for='vibe3')
              span.icon 🚗
              | Late-night
            input.vibe-option(type='radio' name='vibe' id='vibe4' value='Gym energy')
            label.vibe-btn(for='vibe4')
              span.icon 💪
              | Gym energy
            input.vibe-option(type='radio' name='vibe' id='vibe5' value='Feel-good')
            label.vibe-btn(for='vibe5')
              span.icon ☀️
              | Feel-good
            input.vibe-option(type='radio' name='vibe' id='vibe6' value='Emotional')
            label.vibe-btn(for='vibe6')
              span.icon 💭
              | Emotional
            input.vibe-option(type='radio' name='vibe' id='vibe7' value='Focus mode')
            label.vibe-btn(for='vibe7')
              span.icon 🎯
              | Focus mode
            input.vibe-option(type='radio' name='vibe' id='vibe8' value='Party')
            label.vibe-btn(for='vibe8')
              span.icon 🎉
              | Party

          .sliders-row
            .slider-group
              label
                span Mood
                span#happy-val 😊
              input(type='range' name='happy' min='1' max='5' value='3' oninput='updateMood(this)')
              .slider-ends
                span 😢 Sad
                span 😄 Happy
            .slider-group
              label
                span Energy
                span#energy-val ⚡
              input(type='range' name='score' min='1' max='5' value='3' oninput='updateEnergy(this)')
              .slider-ends
                span 😴 Calm
                span 🚀 Energetic

          span.vibe-label What situation fits this playlist?
          .tags-grid
            input.tag-check(type='checkbox' name='situation' id='sit1' value='Study')
            label.tag-pill-btn(for='sit1') 📚 Study
            input.tag-check(type='checkbox' name='situation' id='sit2' value='Party')
            label.tag-pill-btn(for='sit2') 🎉 Party
            input.tag-check(type='checkbox' name='situation' id='sit3' value='Rainy day')
            label.tag-pill-btn(for='sit3') 🌧 Rainy day
            input.tag-check(type='checkbox' name='situation' id='sit4' value='Road trip')
            label.tag-pill-btn(for='sit4') 🚗 Road trip
            input.tag-check(type='checkbox' name='situation' id='sit5' value='Heartbreak')
            label.tag-pill-btn(for='sit5') 💔 Heartbreak
            input.tag-check(type='checkbox' name='situation' id='sit6' value='Morning routine')
            label.tag-pill-btn(for='sit6') ☀️ Morning routine
            input.tag-check(type='checkbox' name='situation' id='sit7' value='Late night')
            label.tag-pill-btn(for='sit7') 🌙 Late night
            input.tag-check(type='checkbox' name='situation' id='sit8' value='Workout')
            label.tag-pill-btn(for='sit8') 💪 Workout
            input.tag-check(type='checkbox' name='situation' id='sit9' value='Focus')
            label.tag-pill-btn(for='sit9') 🎯 Focus
            input.tag-check(type='checkbox' name='situation' id='sit10' value='Chill session')
            label.tag-pill-btn(for='sit10') 😌 Chill session

          textarea.comment-input(name='comment' placeholder='Anything else? (optional)' rows='3')
          button.primary-btn(type='submit') Drop the vibe ✓

      style.
        .vibe-label { font-weight: bold; font-size: 0.95rem; margin-bottom: 12px; display: block; margin-top: 20px; }
        .vibe-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 24px; }
        .vibe-option { display: none; }
        .vibe-btn {
          display: flex; flex-direction: column; align-items: center; gap: 4px;
          padding: 10px 16px; border: 2px solid #d7e4d2; border-radius: 16px;
          cursor: pointer; background: #f4f8f2; transition: all 0.18s ease;
          font-size: 0.88rem; min-width: 80px;
        }
        .vibe-btn .icon { font-size: 1.4rem; }
        .vibe-option:checked + .vibe-btn {
          border-color: #90b08b; background: #e4f0e0; font-weight: bold;
          transform: translateY(-2px);
        }
        .sliders-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
        .slider-group label { display: flex; justify-content: space-between; font-weight: bold; font-size: 0.9rem; margin-bottom: 8px; }
        .slider-ends { display: flex; justify-content: space-between; font-size: 0.8rem; color: #6b756b; margin-top: 4px; }
        input[type="range"] { width: 100%; accent-color: #90b08b; cursor: pointer; }
        .tags-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
        .tag-check { display: none; }
        .tag-pill-btn {
          padding: 6px 12px; border: 1.5px solid #d7e4d2; border-radius: 999px;
          font-size: 0.85rem; cursor: pointer; background: #f4f8f2; transition: all 0.15s ease;
        }
        .tag-check:checked + .tag-pill-btn { background: #b7d3b0; border-color: #90b08b; font-weight: bold; }

      script.
        const moodEmojis = ['😢','😕','😐','😊','😄'];
        const energyEmojis = ['😴','🌿','⚡','🔥','🚀'];
        function updateMood(el) {
          document.getElementById('happy-val').textContent = moodEmojis[el.value-1];
        }
        function updateEnergy(el) {
          document.getElementById('energy-val').textContent = energyEmojis[el.value-1];
        }