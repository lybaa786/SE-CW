extends layout

block content
  main.home-feed-page
    .home-topbar
      h1 Playlist Feed
      input(type="text", placeholder="Search playlists...")

    .welcome-box
      h2 Welcome back, #{user.username} 👋
      p Discover playlists, save your favourites, and join the vibe.

    .playlist-feed
      each playlist in playlists
        .feed-card
          h3 #{playlist.title}
          p.tags
            span [#{playlist.genre}]
          p= playlist.description

          .feed-actions
            span ⭐ 4.5
            span 💬 0 comments
            button(type="button") 💾 Save

    if !playlists || playlists.length === 0
      .empty-feed
        h3 No playlists yet
        p Create the first playlist!